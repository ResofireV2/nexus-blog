{
  "$schema": "https://YOUR-NEXUS-HOST/manifest_schema.json",
  "manifest_version": 2,
  "name": "Blog",
  "slug": "blog",
  "version": "0.1.0",
  "description": "A full-featured community blog with categories, hero images, rich articles, and digest integration.",
  "author": "ResofireV2",
  "homepage": "https://github.com/ResofireV2/nexus-blog",
  "repository": "https://github.com/ResofireV2/nexus-blog",
  "license": "MIT",
  "tags": ["blog", "content", "publishing"],
  "compatible_with": "^0.3.0",
  "module": "Blog",
  "js_bundle": "blog.js",
  "logo_url": "/ext/blog/assets/logo.webp",
  "banner_url": "/ext/blog/assets/banner.webp",
  "settings_schema": {
    "blog_title": {
      "type": "string",
      "label": "Blog title",
      "default": "Blog",
      "description": "Displayed as the page heading and explore sidebar label."
    }
  },
  "settings_tabs": [],
  "hooks": [],
  "routes": [
    {"path": "/",                "title": "Blog"},
    {"path": "/article/:slug",   "title": "Article"},
    {"path": "/category/:slug",  "title": "Category"},
    {"path": "/compose",         "title": "New article"},
    {"path": "/compose/:id",     "title": "Edit article"}
  ],
  "admin_panel": {
    "label": "Blog",
    "icon": "fa-newspaper"
  },
  "explore": {
    "label": "Blog",
    "icon": "fa-newspaper",
    "path": "/"
  },
  "right_widgets": [
    {
      "id": "blog-feed-highlight",
      "label": "From the blog",
      "priority": 30,
      "scope": {"corePages": ["feed"]}
    },
    {
      "id": "blog-recent",
      "label": "Recent articles",
      "priority": 10,
      "scope": "extension"
    },
    {
      "id": "blog-categories",
      "label": "Categories",
      "priority": 20,
      "scope": "extension"
    }
  ],
  "digest_sections": [
    {
      "key": "recent_articles",
      "label": "Latest from the blog",
      "icon": "fa-newspaper",
      "enabled_by_default": true
    }
  ],
  "permissions": [
    {
      "key": "can_view_blog",
      "label": "Can view the blog",
      "default": "everyone"
    },
    {
      "key": "can_write_articles",
      "label": "Can write blog articles",
      "default": "admin"
    },
    {
      "key": "can_publish_articles",
      "label": "Can publish and unpublish blog articles",
      "default": "admin"
    }
  ],
  "slots": [],
  "toolbar_buttons": [],
  "side_data": [],
  "capabilities": []
}
